# ===========================================
# Notion MCP Chatbot - Configuration
# ===========================================
# Copy this file to .env and fill in your keys

# Notion Integration Token (REQUIRED - get from notion.so/my-integrations)
NOTION_API_KEY=ntn_your-key-here

# ---- AI Provider (pick ONE) ----

# Option 1: Anthropic Claude (paid)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Option 2: OpenRouter (has FREE models!)
# Get your key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Free models available on OpenRouter:
#   google/gemini-2.0-flash-exp:free    (best free option - fast, smart)
#   meta-llama/llama-3.3-70b-instruct:free
#   qwen/qwen-2.5-72b-instruct:free
#   deepseek/deepseek-chat-v3-0324:free

# Notion Database IDs (comma-separated, found in database URLs)
# Leave empty to auto-discover all shared databases
NOTION_DATABASE_IDS=

# MCP Auth Token (OPTIONAL - set this and paste the same token in Notion's "Token" field)
# If not set, MCP endpoints have no auth (fine for local dev)
# MCP_AUTH_TOKEN=my-secret-token-here

# Server port (default: 3000)
PORT=3000

# Bot name (shown in chat UI)
BOT_NAME=Notion Assistant

# Max conversation history messages (default: 50)
MAX_HISTORY=50
