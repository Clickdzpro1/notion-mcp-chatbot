# ===========================================
# Notion MCP Chatbot - Configuration
# ===========================================
# Copy this file to .env and fill in your keys

# Notion Integration Token (REQUIRED - get from notion.so/my-integrations)
NOTION_API_KEY=ntn_your-key-here

# Claude API Key (OPTIONAL - only needed for AI tools like summarize, generate, analyze)
# Not needed if your Notion agent already has AI built in (e.g., AGENT ZERO)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Notion Database IDs (comma-separated, found in database URLs)
# Example: https://notion.so/myworkspace/abc123def456...
# Leave empty to auto-discover all shared databases
NOTION_DATABASE_IDS=

# MCP Auth Token (OPTIONAL - set this and paste the same token in Notion's "Token" field)
# If not set, MCP endpoints have no auth (fine for local dev)
# MCP_AUTH_TOKEN=my-secret-token-here

# Server port (default: 3000)
PORT=3000

# Claude model (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Bot name (shown in chat UI)
BOT_NAME=Notion Assistant

# Max conversation history messages (default: 50)
MAX_HISTORY=50
